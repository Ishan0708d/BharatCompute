datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Node {
  id          String  @id @default(uuid())
  name        String  @unique
  type        String
  totalGpus   Int
  usedGpus    Int
  temperature Float
  power       Float
  status      String

  jobs        Job[]
}

model Job {
  id          String   @id @default(uuid())
  name        String
  framework   String
  gpus        Int
  nodeId      String?
  datasetId   String?
  status      String
  stage       String   @default("queued")
  submittedAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  node        Node?           @relation(fields: [nodeId], references: [id])
  dataset     UploadSession?  @relation(fields: [datasetId], references: [id])
}

model UploadSession {
  id        String   @id @default(uuid())
  filename  String
  sizeBytes Int
  progress  Int
  status    String
  createdAt DateTime @default(now())
  
  jobs      Job[]
}

// Persists every telemetry broadcast as a time-series data point.
// DSBDA concept: Data Warehousing, Time-Series Storage, Big Data ingestion pipeline.
// Each row = one snapshot of a node's health at a specific moment in time.
model TelemetrySnapshot {
  id         String   @id @default(uuid())
  nodeName   String
  gpu        Int
  memory     Int
  temp       Float
  power      Float
  recordedAt DateTime @default(now())
}
